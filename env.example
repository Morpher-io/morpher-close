# Rename to .env.local for local development.

# Base mainnet RPC endpoint
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Morpher embedded wallet.
# env selects the iframe origin: 'live' -> https://wallet.morpher.com.
NEXT_PUBLIC_MORPHER_WALLET_ENV=live
NEXT_PUBLIC_MORPHER_WALLET_CHAIN_ID=8453
# Optional: chain RPC the wallet broadcasts through (defaults to NEXT_PUBLIC_BASE_RPC_URL).
# NEXT_PUBLIC_MORPHER_WALLET_RPC=https://mainnet.base.org
